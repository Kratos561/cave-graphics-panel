name: Supabase Keep-Alive

# Objetivo: hacer una consulta REAL a la base de datos cada 3 días,
# muy por debajo del límite de 7 días de inactividad de Supabase Free,
# para que el proyecto "Cave" nunca se pause.

on:
  schedule:
    # Corre a las 12:00 UTC cada 3 días. GitHub puede retrasar el cron
    # unos minutos bajo carga, pero nunca lo suficiente para acercarse
    # a los 7 días — el margen es amplio a propósito.
    - cron: '0 12 */3 * *'
  workflow_dispatch: {}   # también puedes ejecutarlo manualmente desde la pestaña "Actions"

jobs:
  ping-supabase:
    runs-on: ubuntu-latest
    steps:
      - name: Ping a la tabla "tasks" (lectura real, no solo el dashboard)
        run: |
          HTTP_CODE=$(curl -s -o /tmp/response.json -w "%{http_code}" \
            "${SUPABASE_URL}/rest/v1/tasks?select=id&limit=1" \
            -H "apikey: ${SUPABASE_ANON_KEY}" \
            -H "Authorization: Bearer ${SUPABASE_ANON_KEY}")

          echo "Código de respuesta: $HTTP_CODE"
          cat /tmp/response.json

          if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
            echo "✅ Ping exitoso — el proyecto sigue activo."
          else
            echo "⚠️ El ping no devolvió un código 2xx. Revisa las credenciales o el estado del proyecto."
            exit 1
          fi
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_ANON_KEY: ${{ secrets.SUPABASE_ANON_KEY }}
